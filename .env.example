# GitLab private token with "api" scope
# Generate at: https://your-gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=

# Full path of the GitLab group to scan (e.g. my-company/my-team)
GITLAB_GROUP=

# URL of your GitLab instance
GITLAB_URL=https://gitlab.com

# Default base branch (the branch your MR will target)
GITLAB_BASE_BRANCH=master

# PHP version used in your CI — keeps the composer.lock compatible
# Run "php --version" in your CI to find out
COMPOSER_PHP_VERSION=

# Uncomment and set to true if your GitLab uses a self-signed or internal CA certificate
# NO_SSL_VERIFY=true

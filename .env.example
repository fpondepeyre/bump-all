# GitLab private token (scope: api)
# Generate at: https://your-gitlab.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitLab group path (e.g. mycompany/backends)
GITLAB_GROUP=my-org/my-team

# GitLab instance URL (default: https://your-gitlab.com)
GITLAB_URL=https://your-gitlab.com

# Default base branch (default: master)
GITLAB_BASE_BRANCH=master

# PHP version to target for composer resolution (should match your CI PHP version)
COMPOSER_PHP_VERSION=8.3.27

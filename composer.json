{
    "name": "fpondepeyre/bump-all",
    "description": "Update a Composer dependency across all projects in a GitLab group and open a MR for each",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Florian Pondepeyre",
            "homepage": "https://github.com/fpondepeyre"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "symfony/console": "^7.4",
        "m4tthumphrey/php-gitlab-api": "^11.0",
        "guzzlehttp/guzzle": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
